# Auto detect text files and perform LF normalization
* text=auto

# Go source files
*.go text eol=lf

# Markdown documentation
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows batch/powershell scripts
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files (do not modify)
*.png binary
*.jpg binary
*.exe binary
